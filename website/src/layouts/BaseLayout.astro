---
/**
 * BaseLayout.astro — HTML shell with SEO head, skip link, header, footer
 */
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCTA from '../components/mobile/MobileStickyCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalUrl = canonical || Astro.url.pathname;
const siteUrl = `https://trackacademy.co.uk${canonicalUrl}`;
// Full-site navigation is enabled for client review and launch.
const presentationHomeOnly = false;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'NGO',
  name: 'Track Academy',
  url: 'https://trackacademy.co.uk',
  description: 'Athletics, education and mentoring for young people in Brent.',
  nonprofitStatus: 'NonprofitType',
  taxID: '1164222',
  email: 'admin@trackacademy.co.uk',
  telephone: '+447956715052',
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Willesden Sports Centre',
    postalCode: 'NW10 3QX',
    addressCountry: 'GB',
  },
};
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="canonical" href={siteUrl} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={siteUrl} />
  <meta property="og:site_name" content="Track Academy" />
  <meta property="og:locale" content="en_GB" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Preconnect for critical assets -->
  <link rel="preload" href="/fonts/Fredoka-500.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/Fredoka-600.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/Inter-400.ttf" as="font" type="font/ttf" crossorigin />

  <!-- Feed -->
  <link rel="alternate" type="application/rss+xml" title="Track Academy" href="/feed.xml" />

  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)}></script>
</head>
<body>
  <!-- Skip link — accessibility -->
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--color-track-blue)] focus:px-4 focus:py-2 focus:text-white">
    Skip to content
  </a>

  <Header />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <!-- Mobile sticky CTA — "Register your child" bar, appears after scrolling past hero -->
  <MobileStickyCTA />

  {presentationHomeOnly && (
    <script is:inline>
      // Keep the client walkthrough focused on the homepage while leaving the
      // underlying page files intact for the production launch.
      document.addEventListener('click', (event) => {
        if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) return;
        const target = event.target as Element | null;
        const link = target?.closest<HTMLAnchorElement>('a[href]');
        if (!link || link.target === '_blank' || link.hasAttribute('download')) return;

        const url = new URL(link.href, window.location.href);
        if (url.origin === window.location.origin && (url.pathname !== '/' || url.hash)) {
          event.preventDefault();
          window.location.assign('/');
        }
      });
    </script>
  )}
</body>
</html>
