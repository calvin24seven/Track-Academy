---
/**
 * BaseLayout.astro — HTML shell with SEO head, skip link, header, footer
 */
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import MobileStickyCTA from '../components/mobile/MobileStickyCTA.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;
const canonicalUrl = canonical || Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en-GB">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/logo.png" />
  <link rel="canonical" href={`https://trackacademy.co.uk${canonicalUrl}`} />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://trackacademy.co.uk${canonicalUrl}`} />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Preconnect for critical assets -->
  <link rel="preload" href="/fonts/Fredoka-500.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/Fredoka-600.ttf" as="font" type="font/ttf" crossorigin />
  <link rel="preload" href="/fonts/Inter-400.ttf" as="font" type="font/ttf" crossorigin />

  <!-- Feed -->
  <link rel="alternate" type="application/rss+xml" title="Track Academy" href="/feed.xml" />
</head>
<body>
  <!-- Skip link — accessibility -->
  <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--color-track-blue)] focus:px-4 focus:py-2 focus:text-white">
    Skip to content
  </a>

  <Header />

  <main id="main">
    <slot />
  </main>

  <Footer />

  <!-- Mobile sticky CTA — "Register your child" bar, appears after scrolling past hero -->
  <MobileStickyCTA />
</body>
</html>