---
/**
 * TrackEntranceHero.astro — Signature Moment 1: The Track Entrance
 * Type crashes THROUGH the photo, not overlaid on a gradient
 * Requires art direction: photo with clear negative space for type
 *
 * Per art-direction-pro.md:
 * - No gradient overlay
 * - Headline set into negative space of image
 * - 2px Track Orange "track lane line" across bottom
 * - Blur-in on page load, mask-reveal for headline
 */
import { Image } from 'astro:assets';
import HeroImage from '../../assets/stories/girl-smiling.jpg';
import Button from '../ui/Button.astro';

interface Props {
  image?: ImageMetadata;
  headline?: string;
  lead?: string;
}

const {
  image: img = HeroImage,
  headline = 'Every young person deserves somewhere to belong.',
  lead = 'Through athletics, education and mentoring in Brent, we\'re a launchpad for young people to break down barriers, unlock their potential and thrive. Since 2007.',
} = Astro.props;
---

<section class="relative h-[88svh] min-h-[580px] w-full overflow-hidden lg:h-[100svh]">
  <!-- Full-bleed photo — NO gradient overlay. The photo is art-directed with negative space. -->
  <div class="absolute inset-0 animate-blur-in">
    <Image
      src={img}
      alt="A young person smiling at the track, being coached at Track Academy in Brent"
      class="h-full w-full object-cover"
      loading="eager"
      fetchpriority="high"
      widths={[375, 640, 1024, 1920]}
      sizes="100vw"
    />
    <!-- Subtle dark overlay over the full image for text/CTA legibility -->
    <div class="absolute inset-0 bg-[var(--color-track-navy)]/25"></div>
    <!-- Bottom-heavy gradient for the text zone -->
    <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,28,95,0.55)] via-[rgba(10,28,95,0.15)] to-transparent"></div>
  </div>

  <!-- Type set INTO the negative space of the image
       top-[7rem] clears the fixed header (logo h-12 + py-4 = 5rem, plus 2rem buffer)
       justify-center keeps text in the middle of safe zone — never hits header, never clipped -->
  <div class="absolute top-[7rem] right-0 bottom-0 left-0 flex flex-col justify-center px-6 pb-16 lg:px-8 lg:pb-20">
    <div class="mx-auto w-full max-w-[var(--container-content)]">
      <div class="max-w-[var(--container-content)]">
        <h1
          class="animate-mask-reveal font-heading text-[clamp(2.5rem,7vw,5rem)] font-semibold leading-[1.05] tracking-[-0.02em] text-white"
          style="animation-delay: 300ms; animation-fill-mode: both;"
        >
          {headline}
        </h1>
        <p
          class="mt-6 max-w-xl animate-scale-in font-body text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.55] text-white/90"
          style="animation-delay: 500ms; animation-fill-mode: both;"
        >
          {lead}
        </p>
        <div
          class="mt-8 flex flex-col gap-4 animate-scale-in sm:flex-row sm:items-center"
          style="animation-delay: 700ms; animation-fill-mode: both;"
        >
          <Button href="/register" label="Register your child" variant="primary" size="default" />
          <Button href="/schools" label="Partner with us" variant="inverse" size="default" />
        </div>
      </div>
    </div>
  </div>

  <!-- Track lane line: 2px Track Orange across the bottom of the hero -->
  <div class="absolute bottom-0 left-0 right-0 lane-line"></div>
</section>

<style>
  /* Ensure hero fills viewport including dynamic mobile toolbars */
  @media (min-width: 1024px) {
    section {
      height: 100svh;
    }
  }
</style>
