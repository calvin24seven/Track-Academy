---
/**
 * AthleteStack.astro — Signature Moment 4: Swipeable full-bleed portraits
 * NOT 3-up quote cards. A horizontally scroll-snap sequence of full-bleed
 * athlete portraits with pull-quotes set into the negative space.
 *
 * On mobile: swipeable full-screen stack with snap behaviour
 * On desktop: horizontal scroll-snap with dot indicators (not arrows)
 */
import { Image } from 'astro:assets';

interface Athlete {
  quote: string;
  attribution: string;
  context: string;
  image: ImageMetadata;
}

interface Props {
  athletes?: Athlete[];
  title?: string;
}

const {
  athletes = [
    {
      quote: "They taught me to fight — for myself. Now when I say 'I can't,' I hear Coach Nigel say, 'Try again'.",
      attribution: "Ra'elle",
      context: "Age 14, Jack Petchey winner",
      image: (await import('../../assets/stories/girl-smiling.jpg')).default,
    },
    {
      quote: "Her teacher called us shocked — said she's 'a different child.'",
      attribution: "A parent",
      context: "Track Academy family",
      image: (await import('../../assets/stories/coach-closeup.jpg')).default,
    },
    {
      quote: "We are grateful for the positive impact Track Academy has had on our students.",
      attribution: "Kayla Anderson",
      context: "St Claudine's School",
      image: (await import('../../assets/stories/group-photo.jpg')).default,
    },
  ],
  title = 'Stories from the track',
} = Astro.props;
---

<section class="bg-[var(--color-grey-900)] py-[clamp(4rem,10vw,9rem)]">
  <!-- Section header — left-aligned, not centred -->
  <div class="mx-auto mb-[clamp(2rem,5vw,4rem)] max-w-[var(--container-content)] px-6 lg:px-8">
    <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
      Stories
    </p>
    <h2 class="max-w-2xl font-heading text-[clamp(1.75rem,5vw,3rem)] font-500 leading-[1.1] tracking-[-0.01em] text-white">
      {title}
    </h2>
  </div>

  <!-- Horizontal scroll-snap gallery -->
  <div
    class="athlete-scroll no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto px-6 pb-4 lg:px-8"
    role="region"
    aria-label="Athlete stories — swipe to explore"
  >
    {athletes.map((athlete, i) => (
      <article
        class="athlete-card relative flex-[0_0_85vw] snap-center overflow-hidden sm:flex-[0_0_60vw] lg:flex-[0_0_40vw]"
        style={`animation-delay: ${i * 80}ms;`}
      >
        <!-- Full-bleed portrait — aspect-ratio 3/4 (taller than wide, faces read better) -->
        <div class="relative aspect-[3/4] w-full overflow-hidden">
          <Image
            src={athlete.image}
            alt={athlete.attribution}
            class="h-full w-full object-cover transition-transform duration-[600ms] ease-[var(--ease-rest)] hover:scale-105"
            loading="lazy"
            widths={[400, 600, 800]}
            sizes="(max-width: 640px) 85vw, (max-width: 1024px) 60vw, 40vw"
          />
          <!-- Dark scrim at bottom for text legibility — NOT a gradient overlay on the whole image -->
          <div class="absolute inset-0 bg-gradient-to-t from-[rgba(10,28,95,0.85)] via-[rgba(10,28,95,0.15)] to-transparent"></div>
        </div>

        <!-- Pull-quote set into the negative space of the photo -->
        <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-8">
          <blockquote class="font-body text-[clamp(1.125rem,1.8vw,1.5rem)] font-300 italic leading-[1.4] text-white">
            "{athlete.quote}"
          </blockquote>
          <div class="mt-4 flex items-center gap-3">
            <span class="font-body text-sm font-600 text-white">{athlete.attribution}</span>
            <span class="h-1 w-1 rounded-full bg-white/40"></span>
            <span class="font-body text-xs uppercase tracking-[0.05em] text-white/60">{athlete.context}</span>
          </div>
        </div>
      </article>
    ))}
  </div>

  <!-- Dot indicators (not arrows, not progress bar) -->
  <div class="mt-6 flex justify-center gap-2 lg:justify-start lg:px-[max(2rem,calc((100vw-var(--container-content))/2+2rem))]">
    {athletes.map((_, i) => (
      <button
        class="h-1.5 w-1.5 rounded-full bg-white/30 transition-all duration-200 ease-[var(--ease-sprint)] hover:bg-[var(--color-track-orange)]"
        data-dot={i}
        aria-label={`Go to story ${i + 1}`}
      ></button>
    ))}
  </div>
</section>

<style>
  .athlete-card {
    animation: slide-in 300ms var(--ease-stretch) both;
  }
</style>