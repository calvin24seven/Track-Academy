---
/**
 * AudienceRouter.astro — "Who are you?" — 3 audience cards
 * Placed right after the hero per PRD spec section 3.1 (Homepage, item 2)
 * Pattern: Primary/Secondary split (parent is dominant, school + funder share)
 * NOT 3 equal cards — the parent card is larger (Pattern A from art-direction-pro.md)
 */

interface RouteCard {
  heading: string;
  description: string;
  href: string;
  cta: string;
}

const routes: RouteCard[] = [
  {
    heading: "I'm a parent",
    description: 'Register your child for athletics, education, and mentoring. £25 per term — free if on financial support. Ages 5–21.',
    href: '/register',
    cta: 'Register your child',
  },
  {
    heading: "I'm from a school",
    description: 'Partner with us. Pupil Premium pupils funded. Termly Ofsted-ready impact reports.',
    href: '/schools',
    cta: 'Partner with us',
  },
  {
    heading: 'I want to support',
    description: 'Donate, sponsor, or volunteer. Help young people in Brent break down barriers.',
    href: '/support',
    cta: 'Support our work',
  },
];
---

<section class="bg-[var(--color-paper)] py-[clamp(3rem,6vw,5rem)]">
  <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
    <p class="mb-2 text-center font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
      Who are you?
    </p>
    <h2 class="mb-[clamp(2rem,4vw,3rem)] text-center font-heading text-[clamp(1.5rem,4vw,2.25rem)] font-500 leading-[1.15] tracking-[-0.01em] text-[var(--color-track-blue)]">
      Three ways in. One track.
    </h2>

    <!-- Pattern A: Primary (60%) + two secondary cards stacked (40%) -->
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-[7fr_5fr] lg:gap-5">
      <!-- Parent card — primary, dominant -->
      <a
        href={routes[0].href}
        class="group relative flex min-h-[220px] flex-col justify-between overflow-hidden border-2 border-[var(--color-track-orange)] bg-white p-8 transition-all duration-200 ease-[var(--ease-sprint)] hover:shadow-lg lg:p-10"
      >
        <div>
          <h3 class="font-heading text-[clamp(1.25rem,2.5vw,1.75rem)] font-500 text-[var(--color-track-blue)]">
            {routes[0].heading}
          </h3>
          <p class="mt-3 max-w-md font-body text-base leading-[1.6] text-[var(--color-grey-700)]">
            {routes[0].description}
          </p>
        </div>
        <span class="mt-5 inline-flex items-center gap-2 font-body text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)] transition-all duration-150 group-hover:gap-4">
          {routes[0].cta} →
        </span>
      </a>

      <!-- School + Supporter cards — stacked secondary -->
      <div class="grid grid-cols-1 gap-4">
        {routes.slice(1).map((route) => (
          <a
            href={route.href}
            class="group relative flex flex-col justify-between overflow-hidden border border-[var(--color-grey-300)] bg-white p-6 transition-all duration-200 ease-[var(--ease-sprint)] hover:border-[var(--color-track-orange)] hover:shadow-md"
          >
            <div>
              <h3 class="font-heading text-lg font-500 text-[var(--color-track-blue)]">
                {route.heading}
              </h3>
              <p class="mt-2 max-w-sm font-body text-sm leading-[1.55] text-[var(--color-grey-700)]">
                {route.description}
              </p>
            </div>
            <span class="mt-4 inline-flex items-center gap-2 font-body text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)] transition-all duration-150 group-hover:gap-3">
              {route.cta} →
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
