---
/**
 * TrustStrip.astro — partner/funder/trust logos strip
 * Uses Google Favicon API to pull real logos for each organisation
 * Greyscale via CSS filter, colour on hover (per brand-guidelines.md)
 */
interface Partner {
  name: string;
  domain: string;
}

const partners: Partner[] = [
  { name: "St Claudine's School", domain: 'stclaudines.co.uk' },
  { name: 'Newman Catholic College', domain: 'ncc.brent.sch.uk' },
  { name: 'England Athletics', domain: 'englandathletics.org' },
  { name: 'Jack Petchey Foundation', domain: 'jackpetcheyfoundation.org.uk' },
  { name: 'Sported', domain: 'sported.org.uk' },
  { name: 'London Living Wage', domain: 'livingwage.org.uk' },
  { name: 'Laureus', domain: 'laureus.com' },
];

function faviconUrl(domain: string) {
  return `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
}
---

<section class="bg-[var(--color-grey-100)] py-[clamp(3rem,6vw,5rem)]">
  <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
    <div class="mb-6 text-center">
      <p class="font-body text-sm font-medium uppercase tracking-[0.05em] text-[var(--color-grey-500)]">
        Trusted by schools, funders and partners across Brent and beyond
      </p>
    </div>

    <!-- Partner logos — greyscale, colour on hover -->
    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-5 lg:gap-x-14">
      {partners.map((partner) => (
        <div class="group flex flex-col items-center gap-2 opacity-50 grayscale transition-all duration-200 ease-[var(--ease-sprint)] hover:opacity-100 hover:grayscale-0">
          <img
            src={faviconUrl(partner.domain)}
            alt={partner.name}
            class="h-12 w-12 object-contain lg:h-16 lg:w-16"
            loading="lazy"
            width="64"
            height="64"
          />
          <span class="font-body text-xs text-[var(--color-grey-500)] group-hover:text-[var(--color-grey-700)]">
            {partner.name}
          </span>
        </div>
      ))}
    </div>

    <!-- Charity registration — trust signal -->
    <div class="mt-8 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-[var(--color-grey-500)]">
      <span>Registered Charity 1164222</span>
      <span class="h-1 w-1 rounded-full bg-[var(--color-grey-300)]"></span>
      <span>England & Wales</span>
      <span class="h-1 w-1 rounded-full bg-[var(--color-grey-300)]"></span>
      <span>London Living Wage Employer</span>
      <span class="h-1 w-1 rounded-full bg-[var(--color-grey-300)]"></span>
      <span>England Athletics Affiliated</span>
    </div>
  </div>
</section>