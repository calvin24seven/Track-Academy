---
/**
 * TrustBar.astro — concise reassurance directly below the first decision point.
 * It makes safeguarding and charity status easy to find without interrupting the
 * homepage story.
 */
---

<aside class="border-y border-[var(--color-track-blue)]/10 bg-white" aria-label="Track Academy trust and safeguarding information">
  <div class="mx-auto flex max-w-[var(--container-content)] flex-col gap-3 px-6 py-4 text-sm lg:flex-row lg:items-center lg:justify-between lg:px-8">
    <p class="font-body font-semibold text-[var(--color-track-blue)]">
      Registered charity 1164222 <span class="mx-2 text-[var(--color-grey-400)]" aria-hidden="true">•</span> DBS-checked staff and volunteers <span class="mx-2 text-[var(--color-grey-400)]" aria-hidden="true">•</span> Designated Safeguarding Leads
    </p>
    <div class="flex flex-wrap gap-x-4 gap-y-2 font-body font-semibold text-[var(--color-track-orange)]">
      <a href="/safeguarding#policy" class="underline decoration-1 underline-offset-4 transition-colors hover:text-[var(--color-accent-dark)]">Safeguarding policy</a>
      <a href="/safeguarding#reporting" class="underline decoration-1 underline-offset-4 transition-colors hover:text-[var(--color-accent-dark)]">Report a concern →</a>
    </div>
  </div>
</aside>
