---
/**
 * VideoEmbed.astro — YouTube embed with lazy loading
 * Placed high on the homepage per client feedback: "bring video higher"
 * Uses faceted loading: thumbnail image loads first, iframe loads on click
 */
interface Props {
  videoId?: string;
  title?: string;
}

const {
  videoId = 'Wu1qvPAgoXM',
  title = "Annie's story — Track Academy",
} = Astro.props;

const thumbnailUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const embedUrl = `https://www.youtube-nocookie.com/embed/${videoId}`;
---

<section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
  <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
    <div class="mx-auto mb-[clamp(1.5rem,4vw,3rem)] max-w-[var(--container-narrow)] text-center">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Watch
      </p>
      <h2 class="font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        {title}
      </h2>
    </div>

    <!-- Video container — 16/9 aspect, faceted loading -->
    <div class="mx-auto max-w-3xl">
      <div
        class="relative aspect-video w-full overflow-hidden bg-[var(--color-grey-900)]"
        data-video-embed
        data-video-id={videoId}
        data-embed-url={embedUrl}
        role="button"
        tabindex="0"
        aria-label={`Play video: ${title}`}
      >
        <!-- Faceted thumbnail — lazy-loaded, iframe only loads on click for performance -->
        <div class="video-facade absolute inset-0 cursor-pointer transition-opacity duration-300" data-facade>
          <img
            src={thumbnailUrl}
            alt={title}
            class="h-full w-full object-cover opacity-90"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-[var(--color-track-navy)]/40"></div>
          <!-- Play button -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="flex h-20 w-20 items-center justify-center rounded-full bg-[var(--color-track-orange)] transition-transform duration-200 ease-[var(--ease-sprint)] hover:scale-110 active:scale-95">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="white" class="ml-1 h-8 w-8">
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          <p class="absolute bottom-4 left-4 font-body text-sm font-500 text-white/80">{title}</p>
        </div>
        <!-- Iframe loads here on click -->
        <div class="video-iframe-container absolute inset-0 hidden" data-iframe-container></div>
      </div>
    </div>
  </div>
</section>

<script>
  // Faceted loading: click to load the YouTube iframe (saves ~500KB on initial page load)
  const embeds = document.querySelectorAll('[data-video-embed]');
  embeds.forEach((embed) => {
    const facade = embed.querySelector('[data-facade]');
    const container = embed.querySelector('[data-iframe-container]');
    const url = embed.dataset.embedUrl;

    const loadVideo = () => {
      if (!container || !url) return;
      container.innerHTML = `<iframe src="${url}?autoplay=1&rel=0" title="${embed.getAttribute('aria-label')}" allow="autoplay; encrypted-media" allowfullscreen class="h-full w-full"></iframe>`;
      container.classList.remove('hidden');
      facade?.classList.add('hidden');
    };

    embed.addEventListener('click', loadVideo);
    embed.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        loadVideo();
      }
    });
  });
</script>