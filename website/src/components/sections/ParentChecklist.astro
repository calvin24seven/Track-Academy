---
/** ParentChecklist.astro — answers the practical questions a parent needs before registering. */
import Button from '../ui/Button.astro';

const points = [
  'For young people aged 5–21',
  'Based at Willesden Sports Centre, NW10 3QX',
  '£25 per term, with free places available through financial support',
  'Athletics, education and one-to-one mentoring in one place',
];
---

<section class="bg-[var(--color-grey-100)] py-[clamp(3rem,6vw,5rem)]">
  <div class="mx-auto grid max-w-[var(--container-content)] gap-8 px-6 lg:grid-cols-[5fr_4fr] lg:items-center lg:gap-16 lg:px-8">
    <div>
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">For parents</p>
      <h2 class="max-w-xl font-heading text-[clamp(1.75rem,4vw,2.75rem)] font-500 leading-[1.1] text-[var(--color-track-blue)]">Is Track Academy right for my child?</h2>
      <p class="mt-5 max-w-xl font-body text-base leading-[1.65] text-[var(--color-grey-700)]">We use athletics to help young people feel they belong, build confidence and access practical support beyond the track.</p>
    </div>
    <div class="border-l-2 border-[var(--color-track-orange)] bg-white p-7 lg:p-8">
      <ul class="space-y-4" role="list">
        {points.map((point) => (
          <li class="flex gap-3 font-body text-base leading-[1.5] text-[var(--color-grey-900)]">
            <span class="mt-2 h-2 w-2 flex-none rounded-full bg-[var(--color-track-orange)]" aria-hidden="true"></span>
            {point}
          </li>
        ))}
      </ul>
      <p class="mt-6 font-body text-sm text-[var(--color-grey-500)]">Registration takes about 10 minutes and your progress is saved as you go.</p>
      <div class="mt-6 flex flex-wrap gap-4">
        <Button href="/register" label="Register your child" variant="primary" />
        <a href="/safeguarding" class="inline-flex items-center font-body text-sm font-semibold text-[var(--color-track-blue)] underline decoration-[var(--color-track-orange)] underline-offset-4 hover:text-[var(--color-track-orange)]">Read our safeguarding commitment</a>
      </div>
    </div>
  </div>
</section>
