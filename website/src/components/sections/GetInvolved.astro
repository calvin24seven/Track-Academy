---
/**
 * GetInvolved.astro — replaced the 3-up CTA cards
 * Uses Pattern A (Primary/Secondary split, 7fr/5fr) instead of three equal cards
 * Per art-direction-pro.md: no more grid-cols-3 of identical cards
 */
import Button from '../ui/Button.astro';
---

<section class="tracked-surface bg-[var(--color-track-blue)] py-[clamp(3rem,8vw,7rem)]">
  <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
    <div class="mb-[clamp(2rem,5vw,4rem)]">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Get involved
      </p>
      <h2 class="max-w-2xl font-heading text-[clamp(1.75rem,5vw,3rem)] font-500 leading-[1.1] tracking-[-0.01em] text-white">
        Who are you?
      </h2>
    </div>

    <!-- Pattern A: Primary (60%) + Secondary (40%) — NOT 3 equal cards -->
    <div class="grid grid-cols-1 gap-4 lg:grid-cols-[7fr_5fr] lg:gap-6">
      <!-- Primary: Register (60% width, dominant) -->
      <a
        href="/register"
        class="group relative flex min-h-[280px] flex-col justify-between overflow-hidden border border-white/10 p-8 transition-colors duration-200 ease-[var(--ease-sprint)] hover:border-[var(--color-track-orange)] lg:p-10"
      >
        <div>
          <span class="font-heading text-6xl font-300 text-white/20 tabular-nums">01</span>
          <h3 class="mt-4 font-heading text-[clamp(1.5rem,3vw,2.25rem)] font-500 text-white">
            I'm a parent
          </h3>
          <p class="mt-3 max-w-sm font-body text-base text-white/70">
            Register your child for athletics, education, and mentoring in Brent. £25 per term, free if on financial support.
          </p>
        </div>
        <span class="mt-6 inline-flex items-center gap-2 font-body text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)] transition-all duration-150 group-hover:gap-4">
          Register your child →
        </span>
      </a>

      <!-- Secondary: Schools + Support stacked, sharing 40% -->
      <div class="grid grid-cols-1 gap-4">
        <a
          href="/schools"
          class="group relative flex flex-col justify-between overflow-hidden border border-white/10 p-6 transition-colors duration-200 ease-[var(--ease-sprint)] hover:border-[var(--color-track-orange)] lg:flex-1"
        >
          <div>
            <span class="font-heading text-4xl font-300 text-white/20 tabular-nums">02</span>
            <h3 class="mt-3 font-heading text-xl font-500 text-white">
              I'm from a school
            </h3>
            <p class="mt-2 max-w-sm font-body text-sm text-white/70">
              Partner with us. Pupil Premium pupils funded. Termly Ofsted-ready reports.
            </p>
          </div>
          <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)] transition-all duration-150 group-hover:gap-3">
            Partner with us →
          </span>
        </a>

        <a
          href="https://whydonate.com/fundraising/trackacademy"
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col justify-between overflow-hidden border border-white/10 p-6 transition-colors duration-200 ease-[var(--ease-sprint)] hover:border-[var(--color-track-orange)] lg:flex-1"
        >
          <div>
            <span class="font-heading text-4xl font-300 text-white/20 tabular-nums">03</span>
            <h3 class="mt-3 font-heading text-xl font-500 text-white">
              Support our work
            </h3>
            <p class="mt-2 max-w-sm font-body text-sm text-white/70">
              London Living Wage Employer. Registered Charity 1164222.
            </p>
          </div>
          <span class="mt-4 inline-flex items-center gap-2 text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)] transition-all duration-150 group-hover:gap-3">
            Donate now →
          </span>
        </a>
      </div>
    </div>
  </div>
</section>