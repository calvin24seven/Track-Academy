---
/**
 * Footer.astro — Enriched footer per client feedback
 * 4 columns + newsletter signup + trust strip + socials + policies
 */
const footerNav = {
  explore: [
    { label: 'About', href: '/about' },
    { label: 'Impact', href: '/impact' },
    { label: 'Safeguarding', href: '/safeguarding' },
    { label: 'Team', href: '/team' },
    { label: 'Contact', href: '/contact' },
  ],
  programmes: [
    { label: 'Athletics', href: '/athletics' },
    { label: 'Education & Life Skills', href: '/education' },
    { label: 'Mentoring', href: '/mentoring' },
    { label: 'Holiday Programmes', href: '/holiday-programmes' },
    { label: 'Competitions & Fixtures', href: '/competitions' },
    { label: 'Schools Partnership', href: '/schools' },
    { label: 'Events', href: '/events' },
  ],
  involved: [
    { label: 'Register your child', href: '/register' },
    { label: 'Partner with your school', href: '/schools' },
    { label: 'Donate', href: 'https://whydonate.com/fundraising/trackacademy' },
    { label: 'Volunteer', href: '/contact' },
  ],
  resources: [
    { label: '2024 Annual Report (PDF)', href: '/pdfs/annual-report-2024.pdf' },
    { label: 'Safeguarding Policies', href: '/safeguarding' },
    { label: 'Privacy Policy', href: '/privacy' },
  ],
  socials: [
    { label: 'Instagram', href: 'https://instagram.com/trackacademy_', icon: 'instagram' },
    { label: 'LinkedIn', href: 'https://linkedin.com/company/track-academy', icon: 'linkedin' },
    { label: 'Facebook', href: 'https://www.facebook.com/CHTrackAcademy/', icon: 'facebook' },
    { label: 'TikTok', href: 'https://www.tiktok.com/@trackacademy', icon: 'tiktok' },
  ],
};
---

<footer class="tracked-surface bg-[var(--color-track-blue)] text-white">
  <div class="mx-auto max-w-[var(--container-content)] px-6 py-14 pb-24 lg:px-8 lg:py-20">
    <!-- Top row: brand + newsletter -->
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-16">
      <!-- Brand -->
      <div>
        <img src="/logo-white.png" alt="Track Academy" class="mb-4 h-14 w-auto" />
        <p class="font-heading text-lg font-medium">The track has been open since 2007.</p>
        <p class="mt-3 max-w-sm text-sm text-white/60">
          Track Academy (no. 1164222) is a registered charity in England & Wales.
        </p>
        <!-- Social icons -->
        <div class="mt-6 flex gap-4">
          {footerNav.socials.map((s) => (
            <a href={s.href} target="_blank" rel="noopener" class="flex h-9 w-9 items-center justify-center border border-white/20 transition-colors duration-150 ease-[var(--ease-sprint)] hover:border-[var(--color-track-orange)] hover:bg-[var(--color-track-orange)]" aria-label={s.label}>
              {s.icon === 'instagram' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="3" />
                  <circle cx="12" cy="12" r="3.5" />
                  <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                </svg>
              )}
              {s.icon === 'linkedin' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M4 24H0V8h4zM2 4a2 2 0 100-4 2 2 0 000 4zM24 24h-4v-8c0-2-1-3-3-3s-3 1-3 3v8h-4V8h4v2c1-1 2-2 5-2 3 0 5 2 5 6v10z" fill="currentColor" stroke="none" />
                </svg>
              )}
              {s.icon === 'facebook' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
                  <path d="M24 12a12 12 0 10-13.9 12v-8.4h-3V12h3V9.4c0-3 1.8-4.7 4.5-4.7 1.3 0 2.7.2 2.7.2v3h-1.5c-1.5 0-2 .9-2 1.9v2.2h3.4l-.5 3.6h-2.9V24A12 12 0 0024 12z" />
                </svg>
              )}
              {s.icon === 'tiktok' && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
                  <path d="M16.6 5.8a4.3 4.3 0 01-1-2.8h-3v12.3a2.3 2.3 0 11-2.3-2.3c.2 0 .5 0 .7.1V9.9a5.3 5.3 0 00-.7 0 5.3 5.3 0 105.3 5.3V9a7.3 7.3 0 004 1.3V7.3a4.3 4.3 0 01-1-1.5z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <!-- Newsletter -->
      <div>
        <h2 class="font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">
          Newsletter
        </h2>
        <p class="mt-3 max-w-sm text-sm text-white/70">
          Stories from the track — termly updates, event invitations, and impact reports.
        </p>
        <form class="mt-4 flex max-w-sm" onsubmit="return false;">
          <input
            type="email"
            name="email"
            placeholder="Your email"
            aria-label="Email address"
            class="flex-1 border border-white/20 bg-white/5 px-4 py-3 font-body text-sm text-white placeholder:text-white/40 focus:border-[var(--color-track-orange)] focus:outline-none"
          />
          <button
            type="submit"
            class="bg-[var(--color-track-orange)] px-6 py-3 font-body text-sm font-semibold uppercase tracking-wide text-white transition-all duration-150 ease-[var(--ease-sprint)] hover:bg-[var(--color-accent-dark)] active:scale-[0.98]"
          >
            Subscribe
          </button>
        </form>
        <p class="mt-2 text-xs text-white/40">No spam. Unsubscribe anytime.</p>
      </div>
    </div>

    <!-- Divider -->
    <div class="my-10 h-px bg-white/10"></div>

    <!-- Mobile: compact disclosure navigation keeps the footer useful without a long wall of links. -->
    <div class="divide-y divide-white/10 lg:hidden">
      <details>
        <summary class="flex min-h-14 cursor-pointer items-center justify-between font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Explore <span aria-hidden="true">+</span></summary>
        <ul class="space-y-3 pb-5">
          {footerNav.explore.map((l) => (<li><a href={l.href} class="block py-1 text-base text-white/75 hover:text-white">{l.label}</a></li>))}
        </ul>
      </details>
      <details>
        <summary class="flex min-h-14 cursor-pointer items-center justify-between font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Programmes <span aria-hidden="true">+</span></summary>
        <ul class="space-y-3 pb-5">
          {footerNav.programmes.map((l) => (<li><a href={l.href} class="block py-1 text-base text-white/75 hover:text-white">{l.label}</a></li>))}
        </ul>
      </details>
      <details>
        <summary class="flex min-h-14 cursor-pointer items-center justify-between font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Get involved <span aria-hidden="true">+</span></summary>
        <ul class="space-y-3 pb-5">
          {footerNav.involved.map((l) => (<li><a href={l.href} class="block py-1 text-base text-white/75 hover:text-white">{l.label}</a></li>))}
        </ul>
      </details>
      <details>
        <summary class="flex min-h-14 cursor-pointer items-center justify-between font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Resources & contact <span aria-hidden="true">+</span></summary>
        <ul class="space-y-3 pb-5">
          {footerNav.resources.map((l) => (<li><a href={l.href} class="block py-1 text-base text-white/75 hover:text-white">{l.label}</a></li>))}
        </ul>
        <div class="space-y-2 pb-5 text-base text-white/60">
          <a href="mailto:admin@trackacademy.co.uk" class="block hover:text-white">admin@trackacademy.co.uk</a>
          <a href="tel:07956715052" class="block hover:text-white">07956 715052</a>
          <p>Willesden Sports Centre, NW10 3QX</p>
        </div>
      </details>
    </div>

    <!-- Desktop: all four link groups remain visible at a glance. -->
    <div class="hidden grid-cols-2 gap-8 sm:grid-cols-4 lg:grid">
      <nav aria-label="Explore">
        <h3 class="mb-4 font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Explore</h3>
        <ul class="space-y-2.5">
          {footerNav.explore.map((l) => (
            <li><a href={l.href} class="text-sm text-white/70 transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Programmes">
        <h3 class="mb-4 font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Programmes</h3>
        <ul class="space-y-2.5">
          {footerNav.programmes.map((l) => (
            <li><a href={l.href} class="text-sm text-white/70 transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <nav aria-label="Get involved">
        <h3 class="mb-4 font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Get Involved</h3>
        <ul class="space-y-2.5">
          {footerNav.involved.map((l) => (
            <li><a href={l.href} class="text-sm text-white/70 transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
      </nav>

      <div>
        <h3 class="mb-4 font-body text-sm font-semibold uppercase tracking-[0.05em] text-[var(--color-track-orange)]">Resources</h3>
        <ul class="space-y-2.5">
          {footerNav.resources.map((l) => (
            <li><a href={l.href} class="text-sm text-white/70 transition-colors hover:text-white">{l.label}</a></li>
          ))}
        </ul>
        <div class="mt-6 space-y-1 text-sm text-white/50">
          <a href="mailto:admin@trackacademy.co.uk" class="block hover:text-white">admin@trackacademy.co.uk</a>
          <a href="tel:07956715052" class="block hover:text-white">07956 715052</a>
          <p>Willesden Sports Centre, NW10 3QX</p>
        </div>
      </div>
    </div>

    <!-- Bottom trust strip -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 border-t border-white/10 pt-6 text-xs text-white/50">
      <span>Registered Charity 1164222</span>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <span>England & Wales</span>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <span>London Living Wage Employer</span>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <span>England Athletics Affiliated</span>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <a href="/privacy" class="hover:text-white">Privacy</a>
      <span class="h-1 w-1 rounded-full bg-white/20"></span>
      <a href="/safeguarding" class="hover:text-white">Safeguarding</a>
    </div>
  </div>
</footer>
