---
/**
 * Header.astro — Navigation with scroll-aware state change
 * Solid nav that changes background on scroll-past-hero
 * NOT backdrop-blur glassmorphism (anti-pattern from art-direction-pro.md)
 */
const navItems = [
  {
    label: 'About',
    href: '/about',
    children: [
      { label: 'About Us', href: '/about' },
      { label: 'Our Impact', href: '/impact' },
      { label: 'Safeguarding', href: '/safeguarding' },
      { label: 'Meet the Team', href: '/team' },
    ],
  },
  {
    label: 'Programmes',
    href: '/athletics',
    children: [
      { label: 'Athletics Training', href: '/athletics' },
      { label: 'Education & Life Skills', href: '/education' },
      { label: 'Mentoring', href: '/mentoring' },
      { label: 'Holiday Programmes', href: '/holiday-programmes' },
      { label: 'Performance Coaching', href: '/performance-coaching' },
    ],
  },
  { label: 'Schools', href: '/schools' },
  { label: 'Events', href: '/events' },
  { label: 'Competitions', href: '/competitions' },
];
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-200 ease-[var(--ease-sprint)]"
  data-state="top"
>
  <div class="mx-auto flex max-w-[var(--container-content)] items-center justify-between px-6 py-4 lg:px-8">
    <!-- Logo -->
    <a href="/" class="flex items-center" aria-label="Track Academy home">
      <img src="/logo-white.png" alt="Track Academy" class="h-12 w-auto transition-opacity duration-200 header-logo-light" />
      <img src="/logo.png" alt="Track Academy" class="hidden h-12 w-auto transition-opacity duration-200 header-logo-dark" />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-8 lg:flex" aria-label="Main navigation">
      {navItems.map((item) => (
        <div class="group relative">
          <a
            href={item.href}
            class="font-body text-sm font-semibold text-white/90 transition-colors duration-150 hover:text-white header-nav-link"
          >
            {item.label}
          </a>
          {item.children && (
            <div class="invisible absolute left-0 top-full pt-2 opacity-0 transition-all duration-200 ease-[var(--ease-settle)] group-hover:visible group-hover:opacity-100">
              <div class="tracked-surface min-w-[220px] bg-[var(--color-track-blue)] py-2 shadow-xl">
                {item.children.map((child) => (
                  <a
                    href={child.href}
                    class="block px-5 py-2.5 font-body text-sm text-white/80 transition-colors duration-150 hover:bg-white/10 hover:text-white"
                  >
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </nav>

    <!-- CTAs -->
    <div class="hidden items-center gap-4 lg:flex">
      <a href="https://whydonate.com/fundraising/trackacademy" target="_blank" rel="noopener noreferrer" class="font-body text-sm font-semibold text-white/90 transition-colors hover:text-white header-nav-link">
        Support
      </a>
      <a
        href="/register"
        class="bg-[var(--color-track-orange)] px-6 py-2.5 font-body text-sm font-semibold uppercase tracking-wide text-white transition-all duration-150 ease-[var(--ease-sprint)] hover:bg-[var(--color-accent-dark)] active:scale-[0.98]"
      >
        Register
      </a>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="mobile-menu-toggle"
      class="flex flex-col gap-1.5 p-2 lg:hidden"
      aria-label="Open menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 bg-white transition-all duration-200 header-bar"></span>
      <span class="block h-0.5 w-6 bg-white transition-all duration-200 header-bar"></span>
      <span class="block h-0.5 w-6 bg-white transition-all duration-200 header-bar"></span>
    </button>
  </div>
</header>

<!-- Mobile menu drawer -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 hidden bg-[var(--color-track-blue)] tracked-surface"
>
  <div class="flex h-full flex-col overflow-y-auto px-6 py-20">
    {navItems.map((item) => (
      <div class="py-2">
        <a href={item.href} class="font-heading text-2xl font-medium text-white">
          {item.label}
        </a>
        {item.children && (
          <div class="mt-1 pl-4">
            {item.children.map((child) => (
              <a href={child.href} class="block py-1.5 font-body text-base text-white/70 hover:text-white">
                {child.label}
              </a>
            ))}
          </div>
        )}
      </div>
    ))}
    <div class="mt-6 flex gap-4">
      <a href="/register" class="flex-1 bg-[var(--color-track-orange)] px-6 py-4 text-center font-body text-sm font-semibold uppercase tracking-wide text-white">
        Register
      </a>
      <a href="/support" class="flex-1 border-2 border-white px-6 py-4 text-center font-body text-sm font-semibold uppercase tracking-wide text-white">
        Support
      </a>
    </div>
  </div>
</div>

<script>
  // Scroll-aware header: changes from transparent (over hero) to solid (past hero)
  const header = document.getElementById('site-header');
  const mobileToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  function updateHeader() {
    if (window.scrollY > 80) {
      header?.setAttribute('data-state', 'scrolled');
    } else {
      header?.setAttribute('data-state', 'top');
    }
  }

  window.addEventListener('scroll', updateHeader, { passive: true });
  updateHeader();

  mobileToggle?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.contains('hidden') === false;
    if (isOpen) {
      mobileMenu?.classList.add('hidden');
      mobileToggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    } else {
      mobileMenu?.classList.remove('hidden');
      mobileToggle.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
  });
</script>

<style>
  /* Header state: transparent over hero, solid when scrolled */
  #site-header[data-state='top'] {
    background-color: transparent;
  }
  #site-header[data-state='scrolled'] {
    background-color: var(--color-track-blue);
    box-shadow: 0 1px 0 0 rgba(255, 255, 255, 0.1);
  }

  /* Logo visibility: white over hero, dark when scrolled — actually keep white for simplicity on blue header */
  .header-logo-dark { display: none; }

  /* Nav link underline grow from left on hover */
  .header-nav-link {
    position: relative;
  }
  .header-nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    width: 0;
    height: 2px;
    background-color: var(--color-track-orange);
    transition: width 200ms var(--ease-sprint);
  }
  .header-nav-link:hover::after {
    width: 100%;
  }
</style>