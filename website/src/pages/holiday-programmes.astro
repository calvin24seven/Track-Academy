---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import NumeralsEscaping from '../components/sections/NumeralsEscaping.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import GroupPhoto from '../assets/stories/group-photo.jpg';

const seo = {
  title: 'Holiday Programmes — Track Academy',
  description:
    'Keeping young people active, safe and learning when school\'s out. Workshops, trips and activity days across the school holidays.',
};

const activities = [
  'Escape room challenges',
  'Go Ape high ropes',
  'Laser tag',
  'Dodgeball tournaments',
  'Boxing sessions',
  'Film screenings',
  'Card games and board games',
  'ELEVATE CV writing workshop',
  'Thorpe Park trips',
];

const stats = [
  { number: 45, label: 'workshops delivered', context: 'across all holidays' },
  { number: 250, suffix: '+', label: 'students took part', context: 'in 2024' },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={GroupPhoto}
    title="Holiday Programmes"
    lead="Keeping young people active, safe and learning when school's out."
  />

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        What We've Done
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Holidays aren't a gap — they're a launchpad.
      </h2>
      <ul class="grid grid-cols-1 gap-y-3 sm:grid-cols-2 sm:gap-x-8 lg:grid-cols-3 lg:gap-x-12">
        {activities.map((activity) => (
          <li class="flex items-baseline gap-3 border-b border-[var(--color-grey-300)] py-3 font-body text-base text-[var(--color-grey-900)]">
            <span class="font-heading text-sm font-600 text-[var(--color-track-orange)]">—</span>
            {activity}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <NumeralsEscaping
    stats={stats}
    caption="Across summer, Easter, Christmas and half terms."
  />

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Upcoming
      </p>
      <h2 class="mb-6 font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        What's next
      </h2>
      <div class="border-2 border-dashed border-[var(--color-grey-300)] py-[clamp(3rem,8vw,5rem)] text-center">
        <p class="mx-auto max-w-md font-body text-base leading-[1.6] text-[var(--color-grey-500)]">
          No holiday programmes scheduled right now. Check back here when the next school break approaches — or follow us for announcements.
        </p>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want to sponsor a holiday programme?"
    body="Your support keeps workshops and trips free for young people."
    ctaPrimary={{ label: 'Support us', href: '/support' }}
    ctaSecondary={{ label: 'Contact us', href: '/contact' }}
  />
</BaseLayout>