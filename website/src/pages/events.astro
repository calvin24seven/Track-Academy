---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Button from '../components/ui/Button.astro';
import StudentsRacing from '../assets/hero/students-racing.webp';

const seo = {
  title: 'Events at Track Academy',
  description:
    'Events, open days and gatherings at the track. The track doesn\'t stop — sessions run every Tuesday, Thursday and Saturday.',
};

const reasons = [
  { label: '01', heading: 'See us in action', description: 'Watch a session, meet the coaches, and feel the energy of the track.' },
  { label: '02', heading: 'Talk to our team', description: 'Ask about coaching, education, mentoring or partnerships — face to face.' },
  { label: '03', heading: 'Bring the family', description: 'Most events are open to all ages. Come and see what the track feels like.' },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={StudentsRacing}
    title="Events at Track Academy"
    lead="Open days, fixtures and moments worth turning up for."
  />

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Upcoming Events
      </p>
      <h2 class="mb-6 font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        The calendar
      </h2>
      <div class="border-2 border-dashed border-[var(--color-grey-300)] px-6 py-[clamp(3rem,8vw,5rem)]">
        <p class="font-body text-[clamp(1.125rem,1.5vw,1.25rem)] leading-[1.6] text-[var(--color-grey-700)]">
          No events on the calendar right now. The track doesn't stop though — sessions run every Tuesday, Thursday, and Saturday.
        </p>
        <div class="mt-8">
          <Button href="/athletics" label="See session times" variant="primary" />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Why Come Along
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Three reasons to show up.
      </h2>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[7fr_5fr] lg:gap-12">
        <div class="space-y-[clamp(1.5rem,4vw,2.5rem)]">
          {reasons.slice(0, 2).map((reason) => (
            <div class="flex items-start gap-6 border-b border-[var(--color-grey-300)] pb-[clamp(1.5rem,3vw,2rem)]">
              <span class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-300 leading-none text-[var(--color-track-orange)] tabular-nums">{reason.label}</span>
              <div>
                <h3 class="font-heading text-lg font-500 text-[var(--color-grey-900)]">{reason.heading}</h3>
                <p class="mt-2 max-w-md font-body text-sm leading-[1.6] text-[var(--color-grey-500)]">{reason.description}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="bg-white p-8">
          <span class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-300 leading-none text-[var(--color-track-orange)] tabular-nums">{reasons[2].label}</span>
          <h3 class="mt-4 font-heading text-lg font-500 text-[var(--color-grey-900)]">{reasons[2].heading}</h3>
          <p class="mt-2 max-w-md font-body text-sm leading-[1.6] text-[var(--color-grey-500)]">{reasons[2].description}</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Want a heads-up when events happen?"
    body="Follow us or get in touch — we'll let you know."
    ctaPrimary={{ label: 'Contact us', href: '/contact' }}
    ctaSecondary={{ label: 'About Track Academy', href: '/about' }}
  />
</BaseLayout>