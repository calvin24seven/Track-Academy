---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Button from '../components/ui/Button.astro';
import StudentsRacing from '../assets/hero/students-racing.webp';
import { calendarLastReviewed, calendarLinks, trackEvents } from '../data/programme-calendar';

const seo = {
  title: 'Events at Track Academy',
  description: 'Open meets, community days and school opportunities at Track Academy in Brent.',
};

const eventTypes = [
  { label: 'Open meets', heading: 'Race, jump and throw with us', body: 'Track Academy open meets bring athletes together for well-run competition with a community feel.', action: { label: 'Competition information', href: '/competitions' } },
  { label: 'Community events', heading: 'Come down and get involved', body: 'Fundraising days, celebrations and local activity that bring young people, families, partners and Brent together.', action: { label: 'Ask about community events', href: '/contact' } },
  { label: 'Schools and groups', heading: 'Create an opportunity together', body: 'We work with schools and groups on positive sport, mentoring and development opportunities for young people.', action: { label: 'Explore school partnerships', href: '/schools' } },
];

const audiences = [
  { heading: 'Parents and athletes', body: 'Use Spond for club updates, selections, arrival times and practical event information.', action: { label: 'Join Spond', href: calendarLinks.spond, external: true } },
  { heading: 'Schools and partners', body: 'Bring a group, sponsor a day or create a partnership that gives young people more access to sport.', action: { label: 'Partner with us', href: '/schools' } },
  { heading: 'Volunteers', body: 'Events work because local people help make them welcoming, safe and memorable.', action: { label: 'Volunteer with us', href: 'mailto:admin@trackacademy.co.uk?subject=Event%20volunteering%20enquiry', external: false } },
];
---

<BaseLayout {...seo}>
  <SimpleHero image={StudentsRacing} title="Events at Track Academy" lead="Open meets, community days and moments worth turning up for." />

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]" aria-labelledby="event-calendar-heading">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <div class="mb-9 flex flex-col gap-4 border-b border-[var(--color-grey-300)] pb-7 sm:flex-row sm:items-end sm:justify-between">
        <div><p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">What is on</p><h2 id="event-calendar-heading" class="font-heading text-[clamp(1.75rem,4vw,3rem)] font-500 leading-[1.03] tracking-[-0.02em] text-[var(--color-track-blue)]">Upcoming events</h2></div>
        <p class="font-body text-sm text-[var(--color-grey-500)]">Last reviewed: {new Date(`${calendarLastReviewed}T12:00:00`).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
      </div>
      <div id="event-list" class="grid gap-5 md:grid-cols-2">
        {trackEvents.map((event) => (
          <article class="border-t-4 border-[var(--color-track-orange)] bg-[var(--color-grey-100)] p-6" data-event-end={event.endDate || event.startDate}>
            <p class="font-body text-sm font-semibold uppercase tracking-wide text-[var(--color-track-orange)]">{new Date(`${event.startDate}T12:00:00`).toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            <h3 class="mt-3 font-heading text-2xl font-500 leading-[1.05] text-[var(--color-track-blue)]">{event.title}</h3>
            <p class="mt-3 font-body text-sm text-[var(--color-grey-700)]">{event.venue} · {event.audience}</p>
            <p class="mt-3 font-body leading-[1.6] text-[var(--color-grey-700)]">{event.details}</p>
            <div class="mt-6"><Button href={event.actionUrl} label={event.actionLabel} variant="primary" external={event.actionUrl.startsWith('http')} /></div>
          </article>
        ))}
      </div>
      <div id="event-empty" class="border-2 border-dashed border-[var(--color-grey-300)] px-6 py-[clamp(3rem,8vw,5rem)] text-center">
        <p class="mx-auto max-w-xl font-body text-[clamp(1.05rem,1.5vw,1.25rem)] leading-[1.6] text-[var(--color-grey-700)]">No public events are currently confirmed. Club competition updates are shared through Spond; use the links below to find an open meeting or ask about a future Track Academy event.</p>
        <div class="mt-7 flex flex-wrap justify-center gap-3"><Button href="/competitions" label="Competition information" variant="primary" /><Button href={calendarLinks.powerOf10} label="Find open meetings" variant="secondary" external /></div>
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">At Track Academy</p>
      <h2 class="mb-9 max-w-2xl font-heading text-[clamp(1.75rem,4vw,3rem)] font-500 leading-[1.03] tracking-[-0.02em] text-[var(--color-track-blue)]">More than a date in a diary.</h2>
      <div class="grid gap-5 lg:grid-cols-3">{eventTypes.map((event) => (<article class="bg-white p-7"><p class="font-body text-xs font-semibold uppercase tracking-wide text-[var(--color-track-orange)]">{event.label}</p><h3 class="mt-3 font-heading text-2xl font-500 leading-[1.08] text-[var(--color-track-blue)]">{event.heading}</h3><p class="mt-4 font-body leading-[1.6] text-[var(--color-grey-700)]">{event.body}</p><div class="mt-6"><Button href={event.action.href} label={event.action.label} variant="link" /></div></article>))}</div>
    </div>
  </section>

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">Get involved</p>
      <h2 class="mb-9 font-heading text-[clamp(1.75rem,4vw,3rem)] font-500 leading-[1.03] tracking-[-0.02em] text-[var(--color-track-blue)]">There is a route for everyone.</h2>
      <div class="grid gap-5 lg:grid-cols-3">{audiences.map((audience) => (<article class="border-t-2 border-[var(--color-track-orange)] bg-[var(--color-grey-100)] p-6"><h3 class="font-heading text-xl font-500 text-[var(--color-track-blue)]">{audience.heading}</h3><p class="mt-3 font-body leading-[1.6] text-[var(--color-grey-700)]">{audience.body}</p><div class="mt-6"><Button href={audience.action.href} label={audience.action.label} variant="primary" external={audience.action.external} /></div></article>))}</div>
    </div>
  </section>

  <CTABanner heading="Want a heads-up when an event is announced?" body="Join Spond for club updates or contact us about bringing a group, volunteering or partnering with Track Academy." ctaPrimary={{ label: 'Join Spond', href: calendarLinks.spond }} ctaSecondary={{ label: 'Contact us', href: '/contact' }} />
</BaseLayout>

<script>
  const eventRows = [...document.querySelectorAll<HTMLElement>('[data-event-end]')];
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  eventRows.filter((row) => new Date(`${row.dataset.eventEnd}T23:59:59`) < today).forEach((row) => row.remove());
  const empty = document.querySelector<HTMLElement>('#event-empty');
  if (eventRows.some((row) => row.isConnected) && empty) empty.hidden = true;
</script>
