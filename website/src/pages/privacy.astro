---
import BaseLayout from '../layouts/BaseLayout.astro';

const seo = {
  title: 'Privacy Policy — Track Academy',
  description:
    'Track Academy is a registered charity in Brent. Our privacy policy is being prepared and will be available before launch.',
};
---

<BaseLayout {...seo}>
  <section class="bg-[var(--color-paper)] py-[clamp(4rem,10vw,9rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Privacy
      </p>
      <h1 class="mb-6 font-heading text-[clamp(1.75rem,5vw,3rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Privacy Policy
      </h1>
      <p class="max-w-xl font-body text-[clamp(1.125rem,1.5vw,1.25rem)] leading-[1.65] text-[var(--color-grey-700)]">
        This page is being prepared. Our privacy policy will be available here before launch.
      </p>
      <div class="mt-[clamp(2rem,5vw,3rem)] border-t border-[var(--color-grey-300)] pt-6">
        <p class="font-body text-sm text-[var(--color-grey-500)]">
          Questions before then? <a href="/contact" class="font-body text-sm font-600 underline decoration-[var(--color-track-orange)] decoration-2 underline-offset-4 text-[var(--color-track-blue)] hover:text-[var(--color-track-orange)]">Contact us</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>