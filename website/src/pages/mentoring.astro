---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import SplitFeature from '../components/sections/SplitFeature.astro';
import StepFlow from '../components/sections/StepFlow.astro';
import NumeralsEscaping from '../components/sections/NumeralsEscaping.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import CoachDemonstrating from '../assets/hero/coach-demonstrating.jpg';
import CoachCloseup from '../assets/stories/coach-closeup.jpg';

const seo = {
  title: 'Mentoring — Track Academy',
  description:
    'One trusted adult changes everything. One-to-one mentoring that builds confidence, resilience and aspiration.',
};

const steps = [
  { title: 'Trust is built on the track', description: 'Mentoring starts where our young people are most themselves — at the track. Coaches notice who might benefit from extra support.' },
  { title: 'Dedicated mentors provide one-to-one support', description: 'A trained mentor meets the young person regularly, listens, and helps them navigate whatever they\'re facing — at home, at school, in themselves.' },
  { title: 'Young people gain confidence', description: 'With a consistent, caring adult in their corner, young people start to believe in their own potential — and act on it.' },
];

const helpWith = [
  'Confidence and self-esteem',
  'School attendance and engagement',
  'Behaviour and emotional regulation',
  'Goal-setting and future planning',
  'Family and relationship challenges',
  'Transitions — primary to secondary, school to work',
];

const stats = [
  { number: 52, label: 'sessions delivered', context: 'in 2024' },
  { number: 12, label: 'young people matched', context: 'with a mentor' },
  { number: 3, label: 'new mentors', context: 'trained this year' },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={CoachDemonstrating}
    title="Mentoring"
    lead="One trusted adult changes everything."
  />

  <SplitFeature
    image={CoachCloseup}
    imageSide="right"
    label="The Core Idea"
    heading="A consistent adult who shows up."
    body="Mentoring at Track Academy isn't a programme young people opt into — it's a relationship that grows naturally from the track. Our coaches and mentors get to know each young person as an individual, and when someone needs more support, we're already there."
    background="grey"
  />

  <StepFlow
    label="How It Works"
    heading="From the track edge to a lifeline"
    steps={steps}
  />

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        What Mentors Help With
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Support that meets young people where they are.
      </h2>
      <ul class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:gap-6">
        {helpWith.map((item) => (
          <li class="flex items-start gap-3 font-body text-base leading-[1.6] text-[var(--color-grey-900)]">
            <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-track-orange)]"></span>
            {item}
          </li>
        ))}
      </ul>
    </div>
  </section>

  <NumeralsEscaping
    stats={stats}
    caption="Every match is a relationship built to last."
  />

  <CTABanner
    heading="Know a young person who'd benefit from a mentor?"
    body="Talk to us — referrals come from schools, families, and our own coaches."
    ctaPrimary={{ label: 'Contact us', href: '/contact' }}
    ctaSecondary={{ label: 'Meet the team', href: '/team' }}
  />
</BaseLayout>