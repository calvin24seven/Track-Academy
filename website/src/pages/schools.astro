---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import SplitFeature from '../components/sections/SplitFeature.astro';
import StepFlow from '../components/sections/StepFlow.astro';
import AthleteStack from '../components/sections/AthleteStack.astro';
import NumeralsEscaping from '../components/sections/NumeralsEscaping.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Button from '../components/ui/Button.astro';
import CoachBack from '../assets/stories/coach-back.jpg';
import GroupPhoto from '../assets/stories/group-photo.jpg';
import CoachCloseup from '../assets/stories/coach-closeup.jpg';

const seo = {
  title: 'Bright Futures Through Sport — Track Academy for Schools',
  description:
    'A school partnership programme blending athletics, education and mentoring. Measurable impact on attendance, behaviour and aspiration.',
};

const pillars = [
  { label: '01', heading: 'Builds confidence that transfers to the classroom', description: 'Young people who believe in themselves on the track start to believe in themselves in school.' },
  { label: '02', heading: 'Reaches pupils who mainstream sport doesn\'t', description: 'We specialise in the young people who get overlooked — the ones who need a different kind of coach.' },
  { label: '03', heading: 'Measurable, reportable impact', description: 'Every partnership comes with data on attendance, behaviour, skills and wellbeing — ready for your SLT and governors.' },
];

const deliver = [
  'On-site athletics coaching at your school or our track',
  'Small-group mentoring for targeted pupils',
  'Study support, tuition and life-skills sessions',
  'Holiday programmes and enrichment days',
  'CV writing, employability and pathway support',
  'Bespoke provision aligned to your school priorities',
];

const steps = [
  { title: 'Identify', description: 'Together we identify the pupils who\'ll benefit most and the outcomes your school is targeting.' },
  { title: 'We deliver', description: 'Our coaches, mentors and tutors run sessions — on our track, at your school, or a mix — across the term.' },
  { title: 'Review', description: 'We report back with attendance, engagement and impact data — and plan the next term together.' },
];

const impactStats = [
  { number: 66, suffix: '%', label: 'improved school performance' },
  { number: 87, suffix: '%', label: 'gained new skills' },
  { number: 94, suffix: '%', label: 'believe they can achieve their goals' },
  { number: 89, suffix: '%', label: 'feel more connected' },
];

const testimonials = [
  {
    quote: 'We are grateful for the positive impact Track Academy has had on our students. The change is visible in their attendance and their confidence.',
    attribution: 'Kayla Anderson',
    context: 'St Claudine\'s School',
    image: CoachCloseup,
  },
  {
    quote: 'Our pupils who were disengaged from school are now turning up, taking part, and setting goals. It\'s exactly the partnership we hoped for.',
    attribution: 'Mike Finnie',
    context: 'Partner school',
    image: GroupPhoto,
  },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={CoachBack}
    title="Bright Futures Through Sport"
    lead="A school partnership programme that changes attendance, behaviour and aspiration — measured and reportable."
  />

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Why Schools Partner
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] max-w-2xl font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Three reasons your school should work with us.
      </h2>

      <div class="grid grid-cols-1 gap-8 lg:grid-cols-[7fr_5fr] lg:gap-12">
        <div class="space-y-[clamp(1.5rem,4vw,2.5rem)]">
          <div class="flex items-start gap-6 border-b border-[var(--color-grey-300)] pb-[clamp(1.5rem,3vw,2rem)]">
            <span class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-300 leading-none text-[var(--color-track-orange)] tabular-nums">{pillars[0].label}</span>
            <div>
              <h3 class="font-heading text-lg font-500 text-[var(--color-grey-900)]">{pillars[0].heading}</h3>
              <p class="mt-2 max-w-md font-body text-sm leading-[1.6] text-[var(--color-grey-500)]">{pillars[0].description}</p>
            </div>
          </div>
          <div class="flex items-start gap-6 border-b border-[var(--color-grey-300)] pb-[clamp(1.5rem,3vw,2rem)]">
            <span class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-300 leading-none text-[var(--color-track-orange)] tabular-nums">{pillars[1].label}</span>
            <div>
              <h3 class="font-heading text-lg font-500 text-[var(--color-grey-900)]">{pillars[1].heading}</h3>
              <p class="mt-2 max-w-md font-body text-sm leading-[1.6] text-[var(--color-grey-500)]">{pillars[1].description}</p>
            </div>
          </div>
          <div class="flex items-start gap-6">
            <span class="font-heading text-[clamp(2rem,5vw,3.5rem)] font-300 leading-none text-[var(--color-track-orange)] tabular-nums">{pillars[2].label}</span>
            <div>
              <h3 class="font-heading text-lg font-500 text-[var(--color-grey-900)]">{pillars[2].heading}</h3>
              <p class="mt-2 max-w-md font-body text-sm leading-[1.6] text-[var(--color-grey-500)]">{pillars[2].description}</p>
            </div>
          </div>
        </div>
        <div class="bg-[var(--color-grey-100)] p-8">
          <h3 class="font-heading text-lg font-500 text-[var(--color-track-blue)]">What we deliver</h3>
          <ul class="mt-6 space-y-3">
            {deliver.map((item) => (
              <li class="flex items-start gap-3 font-body text-base leading-[1.5] text-[var(--color-grey-900)]">
                <span class="mt-2 h-1.5 w-1.5 flex-shrink-0 rounded-full bg-[var(--color-track-orange)]"></span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <SplitFeature
    image={CoachBack}
    imageSide="right"
    label="Funding Model"
    heading="We help you find the funding."
    body="School partnerships are typically funded through Pupil Premium, PE & Sport Premium, or alternative provision budgets. We'll work with you to build a proposal that fits your budget and your measurable outcomes — and we'll help you make the case to your SLT or governors."
    cta={{ label: 'Start the conversation', href: '/contact' }}
    background="grey"
  />

  <StepFlow
    label="How It Works"
    heading="A partnership in three steps"
    steps={steps}
  />

  <AthleteStack
    title="What schools say"
    athletes={testimonials}
  />

  <NumeralsEscaping
    stats={impactStats}
    caption="Reported by young people on our school programmes. Data you can take to your governors."
  />

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Pricing
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Partnership tiers
      </h2>

      <div class="grid grid-cols-1 gap-5 lg:grid-cols-[5fr_4fr_3fr] lg:items-stretch lg:gap-6">
        <div class="bg-white p-8">
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Bronze</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£1,950</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ year</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">A termly programme of sessions for a targeted group of up to 15 pupils.</p>
        </div>

        <div class="relative border-2 border-[var(--color-track-orange)] bg-white p-8 lg:-translate-y-2 lg:scale-[1.02]">
          <div class="absolute -top-3 left-6 bg-[var(--color-track-orange)] px-3 py-1 font-body text-xs font-600 uppercase tracking-wide text-white">
            Most popular
          </div>
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Silver</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£3,950</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ year</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">Year-round coaching, mentoring and study support for up to 25 pupils.</p>
        </div>

        <div class="bg-white p-8">
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Gold</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£6,950</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ year</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">Full wraparound — athletics, mentoring, tuition, holiday programmes and bespoke provision.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    heading="Let's build a partnership."
    body="Tell us your pupils and your outcomes — we'll build the programme."
    ctaPrimary={{ label: 'Contact us', href: '/contact' }}
  />
</BaseLayout>