---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import StepFlow from '../components/sections/StepFlow.astro';
import Button from '../components/ui/Button.astro';
import GroupPhoto from '../assets/stories/group-photo.jpg';

const seo = {
  title: 'Safeguarding — Track Academy',
  description:
    'Our safeguarding commitment. Every child and young person at Track Academy deserves to feel safe, heard and supported.',
};

const dsls = [
  { name: 'Yvonne Simpson', role: 'Operations Manager / DSL', email: 'yvonne@trackacademy.co.uk' },
  { name: 'Erick Sanchez', role: 'Education & Mentoring Co-ordinator / DSL', email: 'erick@trackacademy.co.uk' },
  { name: 'Patrik Ewe', role: 'CEO', email: 'patrik@trackacademy.co.uk' },
];

const steps = [
  { title: 'Notice', description: 'If something feels wrong or a young person tells you something concerning, take it seriously. Don\'t ignore it.' },
  { title: 'Report', description: 'Contact one of our Designated Safeguarding Leads directly — by email or in person. You don\'t need proof to raise a concern.' },
  { title: 'We act', description: 'Our DSL will listen, record the concern, and follow our safeguarding policy and England Athletics procedures to ensure the young person is safe.' },
];

const externalContacts = [
  { name: 'NSPCC', number: '0808 800 5000', detail: 'Adult helpline for child safety concerns' },
  { name: 'Childline', number: '0800 1111', detail: 'Confidential support for under-19s' },
  { name: 'Emergency', number: '999', detail: 'If a child is in immediate danger' },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={GroupPhoto}
    title="Safeguarding at Track Academy"
    lead="Every child and young person who trains, learns or is mentored with us deserves to feel safe, heard and supported."
  />

  <section id="policy" class="tracked-surface bg-[var(--color-track-blue)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Our Commitment
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] max-w-2xl font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-white">
        We take safeguarding seriously.
      </h2>
      <div class="space-y-6">
        {[
          'Every young person has the right to take part in sport in a safe, supportive environment free from abuse, bullying and harm.',
          'All staff, coaches, mentors and volunteers are DBS-checked and trained in safeguarding.',
          'We follow England Athletics safeguarding policies and report concerns through official channels.',
          'We listen. We act. We never assume someone else will handle it.',
        ].map((point) => (
          <div class="flex items-start gap-4 border-b border-white/10 pb-6">
            <div class="mt-2 h-2 w-2 flex-shrink-0 rounded-full bg-[var(--color-track-orange)]"></div>
            <p class="font-body text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.6] text-white">{point}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        DSLs
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Our Designated Safeguarding Leads
      </h2>
      <div class="grid grid-cols-1 gap-6 lg:grid-cols-3 lg:gap-8">
        {dsls.map((dsl) => (
          <div class="bg-[var(--color-grey-100)] p-6 lg:p-8">
            <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">{dsl.name}</h3>
            <p class="mt-2 font-body text-sm text-[var(--color-grey-500)]">{dsl.role}</p>
            <p class="mt-3 font-body text-sm text-[var(--color-grey-700)]">{dsl.email}</p>
            <div class="mt-6">
              <Button href={`mailto:${dsl.email}?subject=Safeguarding%20concern`} label="Contact about a concern" variant="primary" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div id="reporting">
    <StepFlow
      label="Reporting route"
      heading="How to raise a concern"
      steps={steps}
    />
  </div>

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        External Contacts
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Outside Track Academy
      </h2>
      <div class="space-y-[clamp(1rem,3vw,1.5rem)]">
        {externalContacts.map((contact) => (
          <div class="flex flex-col gap-2 border-b border-[var(--color-grey-300)] pb-[clamp(1rem,2vw,1.5rem)] sm:flex-row sm:items-baseline sm:justify-between">
            <div>
              <h3 class="font-heading text-lg font-500 text-[var(--color-grey-900)]">{contact.name}</h3>
              <p class="mt-1 font-body text-sm text-[var(--color-grey-500)]">{contact.detail}</p>
            </div>
            <span class="font-heading text-xl font-600 text-[var(--color-track-blue)] tabular-nums sm:text-2xl">{contact.number}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="tracked-surface bg-[var(--color-track-navy)] py-[clamp(2.5rem,5vw,4rem)]">
    <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
      <div class="flex flex-col items-start gap-6 sm:flex-row sm:items-center sm:justify-between">
        <div>
          <p class="font-body text-sm font-600 uppercase tracking-[0.05em] text-white/60">Accreditation & Registration</p>
          <p class="mt-1 font-heading text-lg font-400 text-white/90">England Athletics · Charity 1164222 · London Living Wage Employer</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
