---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import SplitFeature from '../components/sections/SplitFeature.astro';
import StepFlow from '../components/sections/StepFlow.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import Button from '../components/ui/Button.astro';
import ReadyToRace from '../assets/programme/ready-to-race.jpg';
import StudentRunning from '../assets/hero/student-running.jpg';

const seo = {
  title: '1-to-1 Performance Coaching — Track Academy',
  description:
    'Tailored 1-to-1 coaching for track athletes AND footballers. Assessment, coaching blocks, performance work and action plans.',
};

const steps = [
  { title: 'Assessment', description: 'We start with a full movement, technical and tactical assessment — your goals, your history, your baseline.' },
  { title: 'Coaching block', description: 'Structured sessions focused on technique, mechanics and event-specific drills tailored to your sport.' },
  { title: 'Performance work', description: 'Race-pace reps, competition simulation and the physical prep that turns training into results.' },
  { title: 'Action plan', description: 'You leave with a written plan — what to work on, when, and how to track your progress between sessions.' },
];
---

<BaseLayout {...seo}>
  <SimpleHero
    image={ReadyToRace}
    title="1-to-1 Performance Coaching"
    lead="Tailored coaching for track athletes AND footballers."
  />

  <SplitFeature
    image={StudentRunning}
    imageSide="left"
    label="What It Is"
    heading="Private coaching that flexes around you."
    body="One-to-one sessions with our head coaches — built around your goals, your sport and your schedule. Whether you're chasing a PB on the track or sharper pace and movement on the pitch, we build a programme that gets you there."
    cta={{ label: 'Enquire about coaching', href: '#enquire' }}
  />

  <StepFlow
    label="Session Structure"
    heading="How a session works"
    steps={steps}
  />

  <section class="bg-[var(--color-grey-100)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Pricing
      </p>
      <h2 class="mb-[clamp(2rem,5vw,3rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Choose your cadence.
      </h2>

      <div class="grid grid-cols-1 gap-5 lg:grid-cols-[5fr_4fr_3fr] lg:items-stretch lg:gap-6">
        <div class="bg-white p-8">
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Starter</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£30</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ week</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">1 session per week. Perfect for maintaining technique alongside club training.</p>
        </div>

        <div class="relative border-2 border-[var(--color-track-orange)] bg-white p-8 lg:-translate-y-2 lg:scale-[1.02]">
          <div class="absolute -top-3 left-6 bg-[var(--color-track-orange)] px-3 py-1 font-body text-xs font-600 uppercase tracking-wide text-white">
            Most popular
          </div>
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Standard</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£50</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ week</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">2 sessions per week. The sweet spot for steady, visible progress.</p>
        </div>

        <div class="bg-white p-8">
          <h3 class="font-heading text-xl font-500 text-[var(--color-grey-900)]">Pro</h3>
          <p class="mt-4 flex items-baseline gap-1">
            <span class="font-heading text-[clamp(2.5rem,6vw,4rem)] font-700 leading-none text-[var(--color-track-blue)] tabular-nums">£80</span>
            <span class="font-body text-sm text-[var(--color-grey-500)]">/ week</span>
          </p>
          <p class="mt-6 font-body text-base leading-[1.6] text-[var(--color-grey-700)]">3 sessions per week. Full-immersion coaching for serious athletes.</p>
        </div>
      </div>
    </div>
  </section>

  <section id="enquire" class="bg-[var(--color-paper)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">
        Enquire
      </p>
      <h2 class="mb-6 max-w-2xl font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">
        Contact us about performance coaching.
      </h2>
      <p class="max-w-md font-body text-base leading-[1.6] text-[var(--color-grey-700)]">
        Tell us your sport, your goals and your availability. We'll match you with the right coach and get you started.
      </p>
      <div class="mt-8">
        <Button href="mailto:patrik@trackacademy.co.uk?subject=Performance%20coaching%20enquiry" label="Contact us about performance coaching" variant="primary" />
      </div>
    </div>
  </section>

  <CTABanner
    heading="Ready to train like it matters?"
    ctaPrimary={{ label: 'Enquire now', href: '#enquire' }}
    ctaSecondary={{ label: 'See athletics sessions', href: '/athletics' }}
  />
</BaseLayout>