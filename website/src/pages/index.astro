---
import BaseLayout from '../layouts/BaseLayout.astro';
import TrackEntranceHero from '../components/sections/TrackEntranceHero.astro';
import AudienceRouter from '../components/sections/AudienceRouter.astro';
import ProgrammeCards from '../components/sections/ProgrammeCards.astro';
import PillarSequence from '../components/sections/PillarSequence.astro';
import VideoEmbed from '../components/sections/VideoEmbed.astro';
import NumeralsEscaping from '../components/sections/NumeralsEscaping.astro';
import AthleteStack from '../components/sections/AthleteStack.astro';
import InstagramFeed from '../components/sections/InstagramFeed.astro';
import SchoolsTeaser from '../components/sections/SchoolsTeaser.astro';
import TrustStrip from '../components/sections/TrustStrip.astro';
import TrustBar from '../components/sections/TrustBar.astro';
import CTABanner from '../components/sections/CTABanner.astro';

const seo = {
  title: 'Track Academy — Athletics, Education & Mentoring in Brent',
  description:
    'Athletics, education and mentoring for young people aged 5–21 in Brent. £25 per term, with free places available through financial support.',
};
---

<BaseLayout {...seo}>
  <TrackEntranceHero
    headline="Every young person deserves somewhere to belong."
    lead="Through athletics, education and mentoring in Brent, we're a launchpad for young people to break down barriers, unlock their potential and thrive. Since 2007."
  />

  <TrustBar />
  <AudienceRouter />
  <ProgrammeCards />
  <PillarSequence />
  <VideoEmbed videoId="Wu1qvPAgoXM" title="Annie's story — Track Academy" />
  <NumeralsEscaping />
  <AthleteStack />

  <!-- Existing Instagram implementation intentionally left unchanged in this pass. -->
  <InstagramFeed />

  <SchoolsTeaser />
  <TrustStrip />
  <CTABanner
    heading="Ready to get involved?"
    body="Register a child or talk to our schools team about bringing Track Academy to more young people."
    ctaPrimary={{ label: 'Register your child', href: '/register' }}
    ctaSecondary={{ label: 'Partner with us', href: '/schools' }}
  />
</BaseLayout>
