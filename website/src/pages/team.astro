---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import CoachCloseup from '../assets/stories/coach-closeup.jpg';

import Matthew from '../assets/team/people/team/matthew.jpg';
import Erick from '../assets/team/people/team/erick-sanchez.jpg';
import Yvonne from '../assets/team/people/team/yvonne-simpson.jpg';
import Claire from '../assets/team/people/team/claire-owen.jpg';
import Allwin from '../assets/team/people/coaches/allwin.jpg';
import Beth from '../assets/team/people/coaches/beth.jpg';
import Dominique from '../assets/team/people/coaches/dominique.jpg';
import Jamie from '../assets/team/people/coaches/jamie-bath.jpg';
import Jimmy from '../assets/team/people/coaches/jimmy-thoronka.jpg';
import Jovana from '../assets/team/people/coaches/jovana.jpg';
import Josh from '../assets/team/people/coaches/josh-kelly.jpg';
import Lumar from '../assets/team/people/coaches/lumar-sylvester.jpg';
import Martin from '../assets/team/people/coaches/martin-hunt.jpg';
import Mia from '../assets/team/people/coaches/mia.jpg';
import Nigel from '../assets/team/people/coaches/nigel-small.jpg';
import Nilrem from '../assets/team/people/coaches/nilrem.jpg';
import Remy from '../assets/team/people/coaches/remy.jpg';
import Ryan from '../assets/team/people/coaches/ryan.jpg';
import Sam from '../assets/team/people/coaches/sam-nash.jpg';
import TaylaCoach from '../assets/team/people/coaches/tayla-brade.jpg';
import Jobe from '../assets/team/people/mentors/jobe-march.jpg';
import Ngozi from '../assets/team/people/mentors/ngozi.jpg';
import Plamedie from '../assets/team/people/mentors/plamedie.jpg';
import Babatunde from '../assets/team/people/tutors/babatunde.jpg';
import Alecia from '../assets/team/people/trustees/alecia-blackford.jpg';
import Amechi from '../assets/team/people/trustees/amechi-okafor.jpg';
import Claudia from '../assets/team/people/trustees/claudia-wilmot.jpg';
import Frederik from '../assets/team/people/trustees/frederik-reynaert.jpg';
import Marion from '../assets/team/people/trustees/marion-delille.jpg';
import Michael from '../assets/team/people/trustees/michael-adams.jpg';
import Patrik from '../assets/team/people/trustees/patrik-ewe.jpg';
import Steve from '../assets/team/people/trustees/steve-mckoy.jpg';
import TaylaTrustee from '../assets/team/people/trustees/tayla-brade.jpg';

const seo = {
  title: 'Meet the Team — Track Academy',
  description: 'Meet the staff, coaches, mentors, tutors and trustees behind Track Academy.',
};

const groups = [
  {
    label: 'Team',
    heading: 'The people behind Track Academy',
    introduction: 'The people who lead, organise and deliver our work with young people.',
    members: [
      { name: 'Matthew Adum-Yeboah', role: 'Head of Sport', image: Matthew },
      { name: 'Yvonne Simpson', role: 'Head of Operations and Youth', image: Yvonne },
      { name: 'Erick Sanchez', role: 'Education and Mentoring Co-ordinator', image: Erick },
      { name: 'Claire Owen', image: Claire },
    ],
  },
  {
    label: 'Coaches',
    heading: 'On the track every session',
    introduction: 'Our coaches create the consistent, encouraging space that helps young people grow through athletics.',
    members: [
      { name: 'Allwin', image: Allwin }, { name: 'Beth', image: Beth },
      { name: 'Dominique', image: Dominique }, { name: 'Jamie Bath', image: Jamie },
      { name: 'Jimmy Thoronka', image: Jimmy }, { name: 'Jovana', image: Jovana },
      { name: 'Josh Kelly', image: Josh }, { name: 'Lumar Sylvester', image: Lumar },
      { name: 'Martin Hunt', image: Martin }, { name: 'Mia', image: Mia },
      { name: 'Nigel Small', image: Nigel }, { name: 'Nilrem', image: Nilrem },
      { name: 'Remy', image: Remy }, { name: 'Ryan', image: Ryan },
      { name: 'Sam Nash', image: Sam }, { name: 'Tayla Brade', image: TaylaCoach },
    ],
  },
  {
    label: 'Mentors',
    heading: 'One-to-one guidance',
    introduction: 'Our mentors help young people reflect, plan and keep moving forward beyond each session.',
    members: [
      { name: 'Jobe March', image: Jobe }, { name: 'Ngozi', image: Ngozi }, { name: 'Plamedie', image: Plamedie },
    ],
  },
  {
    label: 'Tutors',
    heading: 'Academic support',
    introduction: 'Our tutors support young people to build confidence and progress in education.',
    members: [{ name: 'Babatunde', image: Babatunde }],
  },
  {
    label: 'Trustees',
    heading: 'Our Board',
    introduction: 'Our trustees provide oversight, challenge and support for Track Academy’s long-term work.',
    members: [
      { name: 'Alecia Blackford', image: Alecia }, { name: 'Amechi Okafor', image: Amechi },
      { name: 'Claudia Wilmot', image: Claudia }, { name: 'Frederik Reynaert', role: 'Chair', image: Frederik },
      { name: 'Marion Delille', image: Marion }, { name: 'Michael Adams', image: Michael },
      { name: 'Patrik Ewe', image: Patrik }, { name: 'Steve McKoy', image: Steve },
      { name: 'Tayla Brade', image: TaylaTrustee },
    ],
  },
];
---

<BaseLayout {...seo}>
  <SimpleHero image={CoachCloseup} title="Meet the Team" lead="The staff, coaches, mentors, tutors and trustees who show up for young people every week." />

  {groups.map((group, index) => (
    <section class:list={[
      'py-[clamp(3.5rem,8vw,6.5rem)]',
      index % 2 === 0 ? 'bg-[var(--color-paper)]' : 'bg-[var(--color-grey-100)]',
    ]}>
      <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
        <div class="mb-9 max-w-2xl lg:mb-12">
          <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">{group.label}</p>
          <h2 class="mb-4 font-heading text-[clamp(1.85rem,4vw,3.25rem)] font-500 leading-[0.98] tracking-[-0.025em] text-[var(--color-track-blue)]">{group.heading}</h2>
          <p class="font-body text-base leading-[1.6] text-[var(--color-grey-700)] sm:text-lg">{group.introduction}</p>
        </div>

        <div class="grid grid-cols-2 gap-x-4 gap-y-7 sm:grid-cols-3 sm:gap-x-5 sm:gap-y-9 lg:grid-cols-4 lg:gap-x-6 lg:gap-y-11">
          {group.members.map((member) => (
            <article class="group">
              <div class="aspect-[4/5] overflow-hidden bg-[var(--color-track-blue)]">
                <Image src={member.image} alt={`Portrait of ${member.name}`} width={720} height={900} fit="cover" position="center" loading="lazy" sizes="(max-width: 640px) 46vw, (max-width: 1024px) 30vw, 260px" class="h-full w-full object-cover transition duration-500 motion-safe:group-hover:scale-[1.025]" />
              </div>
              <div class="border-b border-[var(--color-grey-300)] py-3">
                <h3 class="font-heading text-lg font-500 leading-[1.05] tracking-[-0.015em] text-[var(--color-track-blue)] sm:text-xl">{member.name}</h3>
                {member.role && <p class="mt-1 font-body text-xs font-semibold uppercase tracking-[0.02em] text-[var(--color-track-orange)]">{member.role}</p>}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="tracked-surface bg-[var(--color-track-navy)] py-[clamp(3.5rem,8vw,6.5rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">Founder</p>
      <h2 class="mb-6 max-w-2xl font-heading text-[clamp(2rem,5vw,3.5rem)] font-500 leading-[1] tracking-[-0.025em] text-white">Connie Henry MBE</h2>
      <p class="max-w-xl font-body text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.65] text-white/80">Founder of Track Academy. Connie believed that athletics was more than a sport — it was a vehicle for profound social change. Her legacy lives on in every young person who steps onto the track.</p>
    </div>
  </section>

  <CTABanner heading="Want to join the team?" body="We're always looking for coaches, mentors and volunteers." ctaPrimary={{ label: 'Get in touch', href: '/contact' }} ctaSecondary={{ label: 'Support us', href: 'https://whydonate.com/fundraising/trackacademy' }} />
</BaseLayout>
