---
import BaseLayout from '../layouts/BaseLayout.astro';
import SimpleHero from '../components/sections/SimpleHero.astro';
import CTABanner from '../components/sections/CTABanner.astro';
import CoachCloseup from '../assets/stories/coach-closeup.jpg';
import { Image } from 'astro:assets';
import StaffImage from '../assets/team/staff.jpg';
import CoachesImage from '../assets/team/coaches.jpg';
import MentorsImage from '../assets/team/mentors.jpg';
import TutorsImage from '../assets/team/tutors.jpg';
import TrusteesImage from '../assets/team/trustees.jpg';

const seo = {
  title: 'Meet the Team — Track Academy',
  description: 'Meet the staff, coaches, mentors, tutors and trustees behind Track Academy.',
};

const groups = [
  {
    label: 'Leadership',
    heading: 'Setting the direction',
    image: StaffImage,
    alt: 'Track Academy leadership team: Patrik Ewe, Yvonne Simpson, Matthew Adum-Yeboah and Erick Sanchez',
    members: 'Patrik Ewe — Chief Executive Officer · Yvonne Simpson — Head of Operations and Youth · Matthew Adum-Yeboah — Head of Sport · Erick Sanchez — Education and Mentoring Co-ordinator',
    tone: 'paper',
  },
  {
    label: 'Coaches',
    heading: 'On the track every session',
    image: CoachesImage,
    alt: 'Track Academy coaches Beth, Dominique, Jimmy, Lumar, Martin, Mia, Nigel, Nilrem and Sam',
    members: 'Beth · Dominique · Jimmy · Lumar · Martin · Mia · Nigel · Nilrem · Sam',
    tone: 'grey',
  },
  {
    label: 'Mentors',
    heading: 'One-to-one guidance',
    image: MentorsImage,
    alt: 'Track Academy mentors Manar, Ngozi and Plamedie',
    members: 'Manar · Ngozi · Plamedie',
    tone: 'paper',
  },
  {
    label: 'Tutors',
    heading: 'Academic support',
    image: TutorsImage,
    alt: 'Track Academy tutors Babatunde and Elizabeth',
    members: 'Babatunde · Elizabeth',
    tone: 'grey',
  },
  {
    label: 'Trustees',
    heading: 'Our Board',
    image: TrusteesImage,
    alt: 'Track Academy trustees Frederik Reynaert, Amechi Okafor, Marion Delille, Michael Adams, Romain Ebanks, Rosie Beadle, Steve McCoy and Tayla Brade',
    members: 'Frederik Reynaert — Chair · Amechi Okafor · Marion Delille · Michael Adams · Romain Ebanks · Rosie Beadle · Steve McCoy · Tayla Brade',
    tone: 'paper',
  },
];
---

<BaseLayout {...seo}>
  <SimpleHero image={CoachCloseup} title="Meet the Team" lead="The staff, coaches, mentors, tutors and trustees who show up for young people every week." />

  {groups.map((group) => (
    <section class:list={[
      'py-[clamp(3rem,8vw,6rem)]',
      group.tone === 'grey' ? 'bg-[var(--color-grey-100)]' : 'bg-[var(--color-paper)]',
    ]}>
      <div class="mx-auto max-w-[var(--container-content)] px-6 lg:px-8">
        <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">{group.label}</p>
        <h2 class="mb-[clamp(1.5rem,4vw,2.5rem)] font-heading text-[clamp(1.5rem,4vw,2.5rem)] font-500 leading-[1.1] tracking-[-0.01em] text-[var(--color-track-blue)]">{group.heading}</h2>
        <figure class="max-w-5xl overflow-hidden bg-white">
          <Image src={group.image} alt={group.alt} class="h-auto w-full object-cover" loading="lazy" widths={[480, 800, 1200]} sizes="(max-width: 1024px) 100vw, 1080px" />
          <figcaption class="border-t border-[var(--color-grey-200)] px-5 py-4 font-body text-sm leading-[1.6] text-[var(--color-grey-700)]">{group.members}</figcaption>
        </figure>
      </div>
    </section>
  ))}

  <section class="tracked-surface bg-[var(--color-track-navy)] py-[clamp(3rem,8vw,6rem)]">
    <div class="mx-auto max-w-[var(--container-narrow)] px-6 lg:px-8">
      <p class="mb-3 font-body text-sm font-semibold uppercase tracking-[-0.05em] text-[var(--color-track-orange)]">Founder</p>
      <h2 class="mb-6 max-w-2xl font-heading text-[clamp(1.75rem,5vw,3rem)] font-500 leading-[1.1] tracking-[-0.01em] text-white">Connie Henry MBE</h2>
      <p class="max-w-xl font-body text-[clamp(1rem,1.5vw,1.25rem)] leading-[1.65] text-white/80">Founder of Track Academy. Connie believed that athletics was more than a sport — it was a vehicle for profound social change. Her legacy lives on in every young person who steps onto the track.</p>
    </div>
  </section>

  <CTABanner heading="Want to join the team?" body="We're always looking for coaches, mentors and volunteers." ctaPrimary={{ label: 'Get in touch', href: '/contact' }} ctaSecondary={{ label: 'Support us', href: 'https://whydonate.com/fundraising/trackacademy' }} />
</BaseLayout>
